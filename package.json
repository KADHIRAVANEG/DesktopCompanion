{
  "name": "desktopcompanion",
  "version": "0.1.0",
  "private": false,
  "description": "Open-source desktop mate (VRM mascot) — transparent, always-on-top, fully customizable. Built with Electron + three-vrm.",
  "license": "MIT",
  "main": "main.cjs",
  "type": "commonjs",
  "scripts": {
    "renderer:build": "vite build --config renderer/vite.config.mjs",
    "start": "npm run renderer:build && electron .",
    "electron:package:win": "npm run renderer:build && electron-packager . DesktopCompanion --platform=win32 --arch=x64 --out=electron-release --overwrite --asar --prune=true --ignore='^/\\.github' --ignore='^/build' --ignore='^/electron-release' --ignore='\\.md$' --ignore='\\.map$'",
    "electron:package:linux": "npm run renderer:build && electron-packager . DesktopCompanion --platform=linux --arch=x64 --out=electron-release --overwrite --asar --prune=true --ignore='^/\\.github' --ignore='^/build' --ignore='^/electron-release' --ignore='\\.md$' --ignore='\\.map$'",
    "electron:package:mac": "npm run renderer:build && electron-packager . DesktopCompanion --platform=darwin --arch=universal --out=electron-release --overwrite --asar --prune=true --ignore='^/\\.github' --ignore='^/build' --ignore='^/electron-release' --ignore='\\.md$' --ignore='\\.map$'"
  },
  "dependencies": {
    "@pixiv/three-vrm": "^3.5.5",
    "@pixiv/three-vrm-animation": "^3.5.5",
    "three": "^0.180.0"
  },
  "devDependencies": {
    "@electron/packager": "^20.0.3",
    "electron": "^43.1.1",
    "vite": "^8.0.16"
  }
}
